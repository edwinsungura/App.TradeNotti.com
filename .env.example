# PostgreSQL connection — app runtime (use the POOLED url in production, e.g. Neon pgbouncer).
DATABASE_URL="postgresql://tradenotti:tradenotti@localhost:5432/tradenotti?schema=public"
# Direct (non-pooled) connection used for migrations. Locally, same as DATABASE_URL.
DIRECT_URL="postgresql://tradenotti:tradenotti@localhost:5432/tradenotti?schema=public"

# OpenAI — leave blank to use the deterministic stub insight generator.
# When set, the daily insight is generated by the OpenAI API.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Broker (MetaTrader 5 via MetaApi.cloud).
# Leave BROKER_PROVIDER=mock to render seeded open trades without credentials.
# Set BROKER_PROVIDER=metaapi and fill the token + account id to pull live MT5 positions.
BROKER_PROVIDER="mock"
METAAPI_TOKEN=""
METAAPI_ACCOUNT_ID=""
METAAPI_REGION="new-york"

# Identifies the demo user/account until auth is added.
DEMO_USER_EMAIL="edwin@tradenotti.com"

# Optional: protects the scheduled /api/cron/sync endpoint. When set, the cron
# caller must send "Authorization: Bearer <CRON_SECRET>" (Vercel Cron does this).
CRON_SECRET=""
