// TradeNotti — Prisma schema
// Postgres-backed. Models cover the Today page: accounts, trades (open/closed),
// trading rules (read here, managed later in the Rules feature) and cached AI insights.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (e.g. Neon pgbouncer) used by the app at runtime.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection used for migrations. Set it to the same
  // value as DATABASE_URL when your provider has no separate pooled endpoint.
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  username  String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  accounts             Account[]
  notes                Note[]
  noteTemplates        NoteTemplate[]
  resourceDocs         ResourceDoc[]
  pins                 Pin[]
  sentPartnerships     Partnership[]  @relation("Requester")
  receivedPartnerships Partnership[]  @relation("Addressee")
}

enum PinDirection {
  LONG
  SHORT
}

// A pinned chart screenshot on the trader's Pinterest-style board.
model Pin {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  image     String        @db.Text // base64 data URL
  symbol    String?
  timeframe String?
  direction PinDirection?
  note      String?       @db.Text
  tags      String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

// A free-form trading document (plan, routine, psychology notes) — same block
// editor as the notebook.
model ResourceDoc {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Untitled")
  content   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum PartnerAccess {
  STATS // share summary stats only
  FULL // share the full journal
}

enum PartnerStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// A two-way accountability link between two users. Each side grants the other a
// chosen access level; the link is live once accepted.
model Partnership {
  id          String        @id @default(cuid())
  requesterId String
  requester   User          @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User          @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      PartnerStatus @default(PENDING)

  requesterAccess PartnerAccess @default(STATS) // what the requester shares
  addresseeAccess PartnerAccess @default(STATS) // what the addressee shares

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// A Notion-style page attached to a calendar day (multiple pages per day allowed).
model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // calendar day, "YYYY-MM-DD"
  title     String   @default("")
  content   Json? // TipTap document JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
}

// A reusable page template the user saves and applies to new notes.
model NoteTemplate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  content   Json? // TipTap document JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum AccountType {
  LIVE
  DEMO
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Display
  label     String // e.g. "FTMO 100k"
  broker    String      @default("MetaTrader 5")
  currency  String      @default("USD")
  type      AccountType @default(LIVE)
  balance   Decimal     @default(0) @db.Decimal(18, 2)

  // Broker connection (MetaApi.cloud). Null until a live account is linked.
  metaApiAccountId String?
  brokerLogin      String?
  brokerServer     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades   Trade[]
  rules    Rule[]
  insights DailyInsight[]

  @@index([userId])
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum TradeGrade {
  HIGH_PROBABILITY
  LOW_PROBABILITY
}

model Trade {
  id        String         @id @default(cuid())
  accountId String
  account   Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Identifier from the broker (MetaApi position/deal id) for idempotent sync.
  externalId String?

  symbol    String // e.g. "EUR/USD"
  direction TradeDirection
  status    TradeStatus    @default(OPEN)
  grade     TradeGrade?

  entry      Decimal  @db.Decimal(18, 5)
  stopLoss   Decimal? @db.Decimal(18, 5)
  takeProfit Decimal? @db.Decimal(18, 5)
  exitPrice  Decimal? @db.Decimal(18, 5)

  volume     Decimal? @db.Decimal(18, 2)
  // Realized P&L for closed trades; unrealized (floating) for open trades.
  pnl        Decimal? @db.Decimal(18, 2)
  rMultiple  Decimal? @db.Decimal(8, 2)

  openedAt   DateTime
  closedAt   DateTime?

  // Manually journaled fields (entered by the trader, not the broker feed).
  notes           String? @db.Text
  marketDirection String? // e.g. "Bullish", "Bearish", "Ranging"
  phaseOfMarket   String? // e.g. "Accumulation", "Markup", "Distribution", "Markdown"
  stopLossNote    String? // trader's own stop-loss note (e.g. "27 pips", "below structure")

  tags        TagsOnTrades[]
  screenshots Screenshot[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([accountId, externalId])
  @@index([accountId, status])
  @@index([accountId, openedAt])
}

enum ScreenshotKind {
  BEFORE
  AFTER
}

// Before/after trade screenshots. Stored as a base64 data URL in the database
// (one image per kind per trade).
model Screenshot {
  id      String         @id @default(cuid())
  tradeId String
  trade   Trade          @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  kind    ScreenshotKind
  dataUrl String         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tradeId, kind])
  @@index([tradeId])
}

model Tag {
  id     String         @id @default(cuid())
  name   String         @unique
  trades TagsOnTrades[]
}

model TagsOnTrades {
  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([tradeId, tagId])
  @@index([tagId])
}

enum RuleCategory {
  TIMING
  RISK
  ENTRY
  MANAGEMENT
}

// Trading rules. Surfaced read-only on the Today page; the full management
// experience is the separate "Rules" feature (built later).
model Rule {
  id        String       @id @default(cuid())
  accountId String
  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  text      String
  category  RuleCategory?
  active    Boolean      @default(true)
  order     Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId, active])
}

// One generated insight per account per day (enables once-a-day caching).
model DailyInsight {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // The calendar day (UTC midnight) the insight is for.
  date      DateTime @db.Date
  category  String // short kicker, e.g. "TIME", "RISK", "EDGE"
  text      String
  // Snapshot of the journal stats the insight was derived from.
  metrics   Json?
  // "openai" or "stub" — records how this insight was produced.
  source    String   @default("stub")

  createdAt DateTime @default(now())

  @@unique([accountId, date])
  @@index([accountId, date])
}
